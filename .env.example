# Clarvis Environment Configuration
# Copy this to .env and fill in real values. Never commit .env itself.
#
# This file is sourced by scripts/cron_env.sh (the cron bootstrap script)
# and by any Python code using dotenv. Only variables that need per-install
# customisation belong here — hardcoded defaults live in cron_env.sh.

# ── Workspace ────────────────────────────────────────────────────────────
# Root of the Clarvis workspace (used by all Python modules and scripts).
# Default in code: /home/agent/.openclaw/workspace
CLARVIS_WORKSPACE=/home/agent/.openclaw/workspace

# ── API Keys (secrets — never commit real values) ────────────────────────
# OpenRouter key — required for task routing (task_router.py), browser
# agent LLM mode, and directive engine.  Obtain from openrouter.ai.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Telegram Delivery ────────────────────────────────────────────────────
# Bot token and chat IDs for digest reports, budget alerts, and spawn
# notifications.  Leave blank to disable Telegram features.
CLARVIS_TG_BOT_TOKEN=your-telegram-bot-token-here
CLARVIS_TG_CHAT_ID=your-personal-chat-id
CLARVIS_TG_GROUP_ID=your-group-chat-id
CLARVIS_TG_REPORTS_TOPIC=5

# ── Graph Backend ────────────────────────────────────────────────────────
# Storage backend for the knowledge graph.  "sqlite" is the default since
# the 2026-03-29 cutover.  Only change if you know what you're doing.
# CLARVIS_GRAPH_BACKEND=sqlite
# CLARVIS_GRAPH_DUAL_WRITE=0

# ── Model Routing ────────────────────────────────────────────────────────
# Kill switch for OpenRouter model routing in task_router.py.
# Set to "false" to disable routing and force all tasks through Claude.
# OPENROUTER_ROUTING=true
# OPENROUTER_MODEL=your-preferred-model

# ── Cognitive Tuning (optional) ──────────────────────────────────────────
# These default to sensible values; override only for experimentation.
# CLARVIS_PARALLEL_RECALL=1         # Parallel memory retrieval (0/1)
# CLARVIS_PREFLIGHT_PARALLEL=1      # Parallel preflight processing (0/1)
# CLARVIS_ACTR_RECALL=1             # ACT-R memory recall (0/1)
# CLARVIS_RECALL_TELEMETRY=0        # Record retrieval telemetry (0/1)
# CLARVIS_GRAPHRAG_BOOST=1           # GraphRAG community boost (0/1)
# CLARVIS_IMPROVE_EXISTING=1        # Improve existing procedures (0/1)

# ── Browser / Ollama (optional) ──────────────────────────────────────────
# Only needed if you use the browser agent or local Ollama vision.
# CLARVIS_CDP_PORT=18800            # Chrome DevTools Protocol port
# CLARVIS_AGENT_MODEL=minimax-m2.5  # Default model for browser agent
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Thread Limits ────────────────────────────────────────────────────────
# Already set in cron_env.sh; override here only if your system differs.
# OPENBLAS_NUM_THREADS=4
# OMP_NUM_THREADS=4
