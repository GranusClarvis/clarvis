# Clarvis — OpenClaw Gateway profile
# Standalone + chat agent (Telegram/Discord) via OpenClaw gateway.
# Generated by install.sh — edit as needed.

# ── Workspace ────────────────────────────────────────────────────────────
CLARVIS_WORKSPACE=__WORKSPACE__

# ── Graph Backend ────────────────────────────────────────────────────────
CLARVIS_GRAPH_BACKEND=sqlite

# ── API Keys (required for gateway) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Telegram Delivery (optional) ─────────────────────────────────────────
# CLARVIS_TG_BOT_TOKEN=your-telegram-bot-token-here
# CLARVIS_TG_CHAT_ID=your-personal-chat-id

# ── Cognitive Tuning ─────────────────────────────────────────────────────
# CLARVIS_PARALLEL_RECALL=1
# CLARVIS_ACTR_RECALL=1
# CLARVIS_GRAPHRAG_BOOST=1.0
