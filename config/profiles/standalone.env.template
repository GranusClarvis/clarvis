# Clarvis — Standalone profile
# Python packages + CLI + brain. No external services.
# Generated by install.sh — edit as needed.

# ── Required ────────────────────────────────────────────────────────────
CLARVIS_WORKSPACE=__WORKSPACE__
CLARVIS_GRAPH_BACKEND=sqlite

# ── Optional: LLM Access ────────────────────────────────────────────────
# OpenRouter key — enables task routing, chat, and autonomous evolution.
# Brain and CLI work without one. Get a key at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=minimax/minimax-m2.5

# ── Advanced: Cognitive Tuning ──────────────────────────────────────────
# CLARVIS_PARALLEL_RECALL=1
# CLARVIS_ACTR_RECALL=1
# CLARVIS_GRAPHRAG_BOOST=1
