# Clarvis — Full Stack profile
# OpenClaw gateway + system crontab + systemd. The reference deployment.
# Generated by install.sh — edit as needed.

# ── Workspace ────────────────────────────────────────────────────────────
CLARVIS_WORKSPACE=__WORKSPACE__

# ── Graph Backend ────────────────────────────────────────────────────────
CLARVIS_GRAPH_BACKEND=sqlite

# ── API Keys (required) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Telegram Delivery ────────────────────────────────────────────────────
CLARVIS_TG_BOT_TOKEN=your-telegram-bot-token-here
CLARVIS_TG_CHAT_ID=your-personal-chat-id
CLARVIS_TG_GROUP_ID=your-group-chat-id
CLARVIS_TG_REPORTS_TOPIC=5

# ── Model Routing ────────────────────────────────────────────────────────
# OPENROUTER_ROUTING=true

# ── Cognitive Tuning ─────────────────────────────────────────────────────
CLARVIS_PARALLEL_RECALL=1
CLARVIS_PREFLIGHT_PARALLEL=1
CLARVIS_ACTR_RECALL=1
CLARVIS_GRAPHRAG_BOOST=1.0

# ── Thread Limits ────────────────────────────────────────────────────────
OPENBLAS_NUM_THREADS=4
OMP_NUM_THREADS=4
